# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Waterfall Configuration (In Order of Execution)
SAMBANOVA_API_KEY=your-sambanova-key
OPENROUTER_API_KEY=your-openrouter-key
GROQ_API_KEY=your-groq-key
CEREBRAS_API_KEY=your-cerebras-key
GEMINI_API_KEY=your-gemini-key

# Upstash QStash Configuration
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# Upstash Redis Configuration (Rate Limiting)
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Application URLs
APP_URL=http://localhost:3000
QSTASH_WORKER_URL=http://localhost:3000/api/worker
